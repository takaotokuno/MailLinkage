{
  "Batch": {
    "LogDirectory": "MailBatchSample/logs"
  },
  "Imap": {
    "Host": "host.docker.internal",
    "Port": 1143,
    "UseSsl": false,
    "UserName": "test@example.local",
    "Password": "password",
    "Mailbox": "INBOX"
  },
  "MailSearch": {
    "SubjectContains": "連携対象",
    "UnreadOnly": true,
    "SinceDays": 7,
    "MaxMessages": 100
  },
  "Api": {
    "BaseUrl": "http://host.docker.internal:5000",
    "Endpoint": "/api/received-mails",
    "TimeoutSeconds": 30
  },
  "Processing": {
    "MarkAsSeenOnSuccess": true
  }
}
