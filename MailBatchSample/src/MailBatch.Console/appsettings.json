{
  "Batch": {
    "LogDirectory": "MailBatchSample/logs"
  },
  "Imap": {
    "Host": "mailserver",
    "Port": 3143,
    "UserName": "test@example.local",
    "Password": "password",
    "Mailbox": "INBOX"
  },
  "MailSearch": {
    "SubjectContains": "連携対象",
    "From": "sender@example.local",
    "SinceDays": 7,
    "MaxMessages": 100
  },
  "Api": {
    "BaseUrl": "http://mailreceiver-api:8080",
    "Endpoint": "/api/received-mails",
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "RetryDelaySeconds": 2
  },
  "Processing": {
    "ProcessedMailbox": "Processed"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] ({RunId}) {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "MailBatchSample/logs/batch-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] ({RunId}) {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Notification": {
    "SmtpHost": "mailserver",
    "SmtpPort": 3025,
    "UserName": "test@example.local",
    "Password": "password",
    "From": "mailbatch@example.local",
    "AdminAddress": "admin@example.local",
    "Templates": [
      {
        "Name": "RunStatus",
        "Subject": "Mail batch {Status}: RunId={RunId}",
        "Body": "Mail batch {Status}.\nRunId: {RunId}\nStatus: {Status}\nExitCode: {ExitCode}\nTotal: {Total}\nSucceeded: {Succeeded}\nFailed: {Failed}"
      },
      {
        "Name": "ValidationError",
        "Subject": "Received mail validation failed: MessageId={MessageId}",
        "Body": "The received mail could not be accepted because it failed validation.\nMessageId: {MessageId}\nSubject: {Subject}\nValidation errors:\n{ValidationErrors}"
      }
    ]
  }
}
