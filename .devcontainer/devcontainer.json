{
  "name": "MailLinkage (.NET 8)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspaces/MailLinkage",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "ms-azuretools.vscode-docker",
        "editorconfig.editorconfig"
      ],
      "settings": {
        "dotnet.defaultSolution": "MailLinkage.sln",
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.codeLens": true
      }
    }
  },
  "forwardPorts": [
    1025,
    1143,
    5000,
    5001,
    8080
  ],
  "portsAttributes": {
    "1025": {
      "label": "GreenMail SMTP"
    },
    "1143": {
      "label": "GreenMail IMAP"
    },
    "5000": {
      "label": "MailReceiver.Api HTTP"
    },
    "5001": {
      "label": "MailReceiver.Api HTTPS"
    },
    "8080": {
      "label": "App/Test service"
    }
  },
  "postCreateCommand": "dotnet restore MailLinkage.sln",
  "remoteUser": "vscode"
}
