root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_style = space
indent_size = 4

[*.{csproj,slnx,props,targets,xml}]
indent_style = space
indent_size = 2

[*.{json,yml,yaml,md,dockerignore,gitignore}]
indent_style = space
indent_size = 2

[*.sln]
indent_style = tab

[Makefile]
indent_style = tab
